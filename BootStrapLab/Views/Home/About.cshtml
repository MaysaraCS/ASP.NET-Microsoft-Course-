@{
    ViewData["Title"] = "About Us";
}

@* ================================================
     STEP 1: PAGE HERO / HEADER BANNER
     - Matches the site's primary color theme from the navbar
     - py-5 gives generous breathing room top and bottom
     - text-center centers everything on all screen sizes
================================================ *@
<section class="bg-primary text-white py-5 mb-5">
    <div class="container text-center">

        @* STEP 2: Page title using display utility for large impactful heading *@
        <h1 class="display-4 fw-bold mb-3">About TechFlow Solutions</h1>

        @* STEP 3: Subtitle using lead for slightly larger body text *@
        <p class="lead mb-0">
            Meet the passionate team behind the technology — and hear from the clients we serve.
        </p>

    </div>
</section>
@* END Page Hero *@


@* ================================================
     STEP 4: TEAM SECTION
     - id="team" allows direct anchor linking from other pages
     - container keeps content centered with responsive side padding
================================================ *@
<section id="team" class="container mb-5">

    @* STEP 5: Section heading block — centered on all screens *@
    <div class="text-center mb-5">
        <h2 class="fw-bold">Meet Our Team</h2>
        <p class="text-muted">The talented people who make TechFlow Solutions great.</p>
    </div>

    @* STEP 6: Responsive GRID ROW for team cards
         - g-4 adds consistent horizontal AND vertical gutters between cards
           so cards never touch each other on any screen size *@
    <div class="row g-4">

        @* ============================================
             STEP 7: TEAM CARD 1 — CEO
             Responsive column breakpoints:
               col-xl-3  = 4 cards per row on extra-large screens (≥1200px)
               col-lg-4  = 3 cards per row on large screens (≥992px)
               col-md-6  = 2 cards per row on medium screens (≥768px)
               col-sm-12 = 1 card per row on small screens (<768px)
        ============================================ *@
        <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12">

            @* h-100 stretches all cards to equal height within each row *@
            <div class="card h-100 shadow-sm text-center">

                @* STEP 8: Team member photo
                     - img-fluid makes the image scale responsively with its container
                     - rounded-top clips the top corners to match the card border-radius
                     - Using placeholder.co for placeholder images — replace with real photos
                     - alt text is required for accessibility *@
                <img src="https://placehold.co/400x300?text=Sarah+Johnson"                     class="card-img-top img-fluid"
                     alt="Sarah Johnson - CEO" />

                <div class="card-body p-4">

                    @* STEP 9: Member name *@
                    <h5 class="card-title fw-bold mb-1">Sarah Johnson</h5>

                    @* STEP 10: Job title styled with primary color and smaller font *@
                    <p class="text-primary fw-semibold small mb-3">Chief Executive Officer</p>

                    @* STEP 11: Brief bio description *@
                    <p class="card-text text-muted small">
                        15+ years of experience in software architecture and business strategy.
                        Passionate about building products that make a real difference.
                    </p>
                </div>
            </div>
        </div>
        @* END Team Card 1 *@


        @* ============================================
             STEP 12: TEAM CARD 2 — CTO
             Same column classes on every card for consistent grid behavior
        ============================================ *@
        <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12">
            <div class="card h-100 shadow-sm text-center">

                <img src="https://placehold.co/400x300?text=James+Rivera"                     class="card-img-top img-fluid"
                     alt="James Rivera - CTO" />

                <div class="card-body p-4">
                    <h5 class="card-title fw-bold mb-1">James Rivera</h5>
                    <p class="text-primary fw-semibold small mb-3">Chief Technology Officer</p>
                    <p class="card-text text-muted small">
                        Cloud infrastructure expert with deep expertise in distributed systems,
                        DevOps pipelines, and scalable microservice architectures.
                    </p>
                </div>
            </div>
        </div>
        @* END Team Card 2 *@


        @* ============================================
             STEP 13: TEAM CARD 3 — Lead Designer
        ============================================ *@
        <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12">
            <div class="card h-100 shadow-sm text-center">

                <img src="https://placehold.co/400x300?text=Aisha+Patel" class="card-img-top img-fluid"
                     alt="Aisha Patel - Lead Designer" />

                <div class="card-body p-4">
                    <h5 class="card-title fw-bold mb-1">Aisha Patel</h5>
                    <p class="text-primary fw-semibold small mb-3">Lead UI/UX Designer</p>
                    <p class="card-text text-muted small">
                        Award-winning designer focused on crafting intuitive, accessible,
                        and visually stunning digital experiences across web and mobile.
                    </p>
                </div>
            </div>
        </div>
        @* END Team Card 3 *@


        @* ============================================
             STEP 14: TEAM CARD 4 — Head of Security
             On lg screens (col-lg-4 = 3 per row) this 4th card drops
             to a second row — that is expected and correct behavior
        ============================================ *@
        <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12">
            <div class="card h-100 shadow-sm text-center">

                <img src="https://placehold.co/400x300?text=Marcus+Chen" class="card-img-top img-fluid"
                     alt="Marcus Chen - Head of Security" />

                <div class="card-body p-4">
                    <h5 class="card-title fw-bold mb-1">Marcus Chen</h5>
                    <p class="text-primary fw-semibold small mb-3">Head of Cybersecurity</p>
                    <p class="card-text text-muted small">
                        Certified ethical hacker and security architect with a track record
                        of protecting Fortune 500 companies from emerging cyber threats.
                    </p>
                </div>
            </div>
        </div>
        @* END Team Card 4 *@

    </div>
    @* END .row (team grid) *@

</section>
@* END Team Section *@


@* ================================================
     STEP 15: VISUAL DIVIDER between sections
     - Subtle horizontal rule with margin to separate team from testimonials
================================================ *@
<hr class="my-5" />


@* ================================================
     STEP 16: TESTIMONIALS SECTION
     - bg-light gives a subtle contrast background vs the white team section
     - py-5 adds vertical breathing room inside the section
================================================ *@
<section id="testimonials" class="bg-light py-5 mb-5">
    <div class="container">

        @* STEP 17: Section heading — centered above the carousel *@
        <div class="text-center mb-5">
            <h2 class="fw-bold">What Our Clients Say</h2>
            <p class="text-muted">Real feedback from the businesses we've helped grow.</p>
        </div>

        @* STEP 18: Bootstrap CAROUSEL component
             - id="testimonialsCarousel" links controls to this specific carousel
             - data-bs-ride="carousel" auto-plays the carousel on page load
             - data-bs-interval="6000" sets 6 seconds between auto-slides *@
        <div id="testimonialsCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="6000">

            @* STEP 19: Carousel slide indicators (the dots at the bottom)
                 - data-bs-target must match the carousel's id
                 - data-bs-slide-to index must match the order of .carousel-item slides
                 - "active" class + aria-current="true" marks the first dot as selected *@
            <div class="carousel-indicators">
                <button type="button"          data-bs-target="#testimonialsCarousel"             data-bs-slide-to="0"
                        class="active bg-primary"                    aria-current="true"  aria-label="Testimonial 1"></button>
                <button type="button"     data-bs-target="#testimonialsCarousel"         data-bs-slide-to="1"            class="bg-primary"
                        aria-label="Testimonial 2"></button>
                <button type="button"                    data-bs-target="#testimonialsCarousel" data-bs-slide-to="2"    class="bg-primary"
                        aria-label="Testimonial 3"></button>
            </div>
            @* END carousel indicators *@

            @* STEP 20: Carousel SLIDES WRAPPER
                 - Every direct child with class carousel-item is one slide
                 - The first slide MUST have the "active" class or nothing shows *@
            <div class="carousel-inner">

                @* ----------------------------------------
                     STEP 21: SLIDE 1 — First testimonial
                     - active class is REQUIRED on the first slide
                ---------------------------------------- *@
                <div class="carousel-item active">
                    <div class="card border-0 shadow-sm mx-auto" style="max-width: 720px;">
                        <div class="card-body p-5 text-center">

                            @* STEP 22: Large decorative quote mark *@
                            <div class="display-4 text-primary mb-3">&ldquo;</div>

                            @* STEP 23: The testimonial quote text *@
                            <p class="card-text fs-5 text-muted fst-italic mb-4">
                                TechFlow Solutions completely transformed our online presence.
                                Their team delivered a robust web platform on time and under budget.
                                I couldn't be happier with the results.
                            </p>

                            @* STEP 24: Client name and company *@
                            <h6 class="fw-bold mb-0">Emily Carter</h6>
                            <small class="text-muted">CEO, BrightPath Retail</small>
                        </div>
                    </div>
                </div>
                @* END Slide 1 *@

                @* ----------------------------------------
                     STEP 25: SLIDE 2 — Second testimonial
                     - No "active" class — Bootstrap handles showing/hiding
                ---------------------------------------- *@
                <div class="carousel-item">
                    <div class="card border-0 shadow-sm mx-auto" style="max-width: 720px;">
                        <div class="card-body p-5 text-center">
                            <div class="display-4 text-primary mb-3">&ldquo;</div>
                            <p class="card-text fs-5 text-muted fst-italic mb-4">
                                The cybersecurity audit from TechFlow gave us complete peace of mind.
                                Their detailed report and remediation roadmap were invaluable.
                                We've seen zero incidents since implementing their recommendations.
                            </p>
                            <h6 class="fw-bold mb-0">David Nguyen</h6>
                            <small class="text-muted">CTO, NovaTech Logistics</small>
                        </div>
                    </div>
                </div>
                @* END Slide 2 *@

                @* ----------------------------------------
                     STEP 26: SLIDE 3 — Third testimonial
                ---------------------------------------- *@
                <div class="carousel-item">
                    <div class="card border-0 shadow-sm mx-auto" style="max-width: 720px;">
                        <div class="card-body p-5 text-center">
                            <div class="display-4 text-primary mb-3">&ldquo;</div>
                            <p class="card-text fs-5 text-muted fst-italic mb-4">
                                Migrating to the cloud felt daunting, but TechFlow made it seamless.
                                Our infrastructure costs dropped by 40% and performance has never been better.
                                Truly exceptional work from start to finish.
                            </p>
                            <h6 class="fw-bold mb-0">Priya Sharma</h6>
                            <small class="text-muted">Director of Engineering, CloudBase Inc.</small>
                        </div>
                    </div>
                </div>
                @* END Slide 3 *@

            </div>
            @* END .carousel-inner *@

            @* STEP 27: Previous / Next ARROW CONTROLS
                 - data-bs-target links each button to this carousel by id
                 - data-bs-slide="prev"/"next" tells Bootstrap which direction to slide
                 - visually-hidden spans are read by screen readers for accessibility *@
            <button class="carousel-control-prev" type="button"               data-bs-target="#testimonialsCarousel"
                    data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>

            <button class="carousel-control-next" type="button"                  data-bs-target="#testimonialsCarousel"
                    data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
            @* END arrow controls *@

        </div>
        @* END #testimonialsCarousel *@

    </div>
</section>
@* END Testimonials Section *@