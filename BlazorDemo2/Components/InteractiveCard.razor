<div class="@(isExpanded ? "card expanded" : "card collapsed")">
    <div class="card-header">
        <h3>Interactive Product Card</h3>
        <button type="button" class="expand-button" @onclick="ToggleExpanded">
            @(isExpanded ? "Hide Details" : "Show Details")
        </button>
    </div>
    @if (isExpanded)
    {
        <div class="card-body">
            <p>This is an interactive product card.</p>
            <ul>
                <li>Feature 1: High-quality materials</li>
                <li>Feature 2: Innovative design</li>
                <li>Feature 3: Affordable price</li>
            </ul>
        </div>
    }
</div>

<div class="form-section">
    <label for="productName">Product Name:</label>
    <input id="productName" type="text" @bind="productName" @bind:event="oninput" />
    <p>Current Value: @productName</p>
</div>

@code {
    private bool isExpanded = false;
    private string productName = "sample product";

    private void ToggleExpanded()
    {
        isExpanded = !isExpanded;
    }
}