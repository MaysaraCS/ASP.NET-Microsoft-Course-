@* Components/ProjectCard.razor *@
@using PersonalPortfolio.Models

<div class="col-md-6 col-lg-4 mb-4">
    <div class="card project-card h-100 shadow-sm border-0">
        @if (!string.IsNullOrEmpty(Project.ImageUrl))
        {
            <img src="@Project.ImageUrl" class="card-img-top" alt="@Project.Title"
                 style="height: 200px; object-fit: cover;">
        }
        else
        {
            <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 200px;">
                <i class="fas fa-code fa-3x text-white opacity-50"></i>
            </div>
        }

        <div class="card-body d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start mb-1">
                <h5 class="card-title mb-0">@Project.Title</h5>
                @if (Project.IsFeatured)
                {
                    <span class="badge bg-warning text-dark">⭐ Featured</span>
                }
            </div>

            <p class="card-text text-muted small">@Project.Description</p>

            <div class="mb-3">
                @foreach (var tech in Project.TechStack.Split(','))
                {
                    <span class="badge bg-secondary me-1 mb-1">@tech.Trim()</span>
                }
            </div>

            <div class="mt-auto d-flex gap-2 flex-wrap">
                @if (!string.IsNullOrEmpty(Project.LiveUrl))
                {
                    <a href="@Project.LiveUrl" class="btn btn-primary btn-sm" target="_blank">
                        <i class="fas fa-external-link-alt me-1"></i> Live Demo
                    </a>
                }

                @* ✅ GitHub link button added here *@
                @if (!string.IsNullOrEmpty(Project.GitHubUrl))
                {
                    <a href="@Project.GitHubUrl" class="btn btn-outline-dark btn-sm" target="_blank">
                        <i class="fab fa-github me-1"></i> GitHub
                    </a>
                }
            </div>

            <div class="mt-2">
                <small class="text-muted">
                    <i class="fas fa-calendar-alt me-1"></i>
                    Completed: @Project.CompletedDate.ToString("MMM yyyy")
                </small>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public Project Project { get; set; } = new();
}