<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Personal Portfolio</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500&display=swap"
          rel="stylesheet">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/portfolio.css" asp-append-version="true" />
</head>
<body>

    <!-- ✅ Responsive Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand" href="/">
                <span class="brand-bracket">&lt;</span>YourName<span class="brand-bracket">/&gt;</span>
            </a>

            <!-- Hamburger toggle for mobile -->
            <button class="navbar-toggler border-0" type="button"             data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Nav links — collapse on mobile, horizontal on lg+ -->
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto gap-lg-2">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                               href="/">
                            <i class="fas fa-home me-1"></i>Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "About" ? "active" : "")"
                               href="/Home/About">
                            <i class="fas fa-user me-1"></i>About
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Projects" ? "active" : "")"
                               href="/Home/Projects">
                            <i class="fas fa-code me-1"></i>Projects
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-outline-light btn-sm px-3 ms-lg-2
                            @(ViewContext.RouteData.Values["action"]?.ToString() == "Contact" ? "active" : "")"
                               href="/Home/Contact">
                            <i class="fas fa-envelope me-1"></i>Contact
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Page Content -->
    <main role="main" class="pt-5">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer py-4">
        <div class="container text-center">
            <p class="mb-2 text-muted small">
                Built with <i class="fas fa-heart text-danger"></i> using ASP.NET Core & Blazor
            </p>
            <div class="d-flex justify-content-center gap-3">
                <a href="https://github.com/yourusername" target="_blank" class="footer-link">
                    <i class="fab fa-github"></i>
                </a>
                <a href="https://linkedin.com/in/yourprofile" target="_blank" class="footer-link">
                    <i class="fab fa-linkedin"></i>
                </a>
                <a href="mailto:your@email.com" class="footer-link">
                    <i class="fas fa-envelope"></i>
                </a>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Blazor JS -->
    <script src="_framework/blazor.server.js"></script>

    <!-- Navbar scroll effect -->
    <script>
        window.addEventListener('scroll', () => {
        const nav = document.getElementById('mainNav');
        nav.classList.toggle('navbar-scrolled', window.scrollY > 50);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>