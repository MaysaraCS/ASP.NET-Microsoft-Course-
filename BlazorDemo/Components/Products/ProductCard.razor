@* ProductCard.razor *@
<div class="product-card">
    <img src="@ImageUrl" alt="@ProductName" class="product-image" />
    <div class="product-info">
        <h3 class="product-name">@ProductName</h3>
        <p class="product-description">@Description</p>
        <div class="product-footer">
            <p class="price">@Price.ToString("C")</p>
            <button class="btn-add-cart" @onclick="HandleAddToCart">
                Add to Cart
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public string ProductName { get; set; } = string.Empty;
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public decimal Price { get; set; }
    [Parameter] public string ImageUrl { get; set; } = string.Empty;
    [Parameter] public EventCallback OnAddToCart { get; set; }
    private async Task HandleAddToCart()
    {
        await OnAddToCart.InvokeAsync();
    }
}