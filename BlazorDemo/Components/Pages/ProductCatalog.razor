@page "/products"
@rendermode InteractiveServer

<PageTitle>Product Catalog</PageTitle>
@if (!string.IsNullOrEmpty(cartMessage))
{
    <div style="background-color: #d4edda; border: 1px solid #c3e6cb; color: #155724; padding: 15px; margin:10px;
        border-radius:5px; position: relative;">
        @cartMessage
        <button type="button"        @onclick="ClearMessage"        style="position: absolute;
            right: 10px;
            top: 10px;
            background: none;
            border: none;
            font-size: 18px;
            cursor: pointer;
            ">&times;
        </button>
    </div>
}
<ProductList Title="Featured Products" Products="@products" OnProductAddedToCart="@HandleProductAddedToCart" />
@code {
    private string cartMessage = string.Empty;
    private List<Product> products = new List<Product>
    {
        new Product { Name = "Smartphone", Description = "Latest model with advanced features", Price = 699.99m, ImageUrl =
"https://via.placeholder.com/150" },
        new Product { Name = "Laptop", Description = "Powerful performance for work and play", Price = 1299.99m, ImageUrl =
"https://via.placeholder.com/150" },
        new Product { Name = "Headphones", Description = "Noise-cancelling for immersive sound", Price = 199.99m, ImageUrl =
"https://via.placeholder.com/150" },
        new Product { Name = "Smartwatch", Description = "Stay connected on the go", Price = 249.99m, ImageUrl =
"https://via.placeholder.com/150" }
    };
    private void HandleProductAddedToCart(Product product)
    {
        // show visible feedback
        cartMessage = $"Added '{product.Name}' to cart! (${product.Price:F2})";
        StateHasChanged(); // FORCE ui Update
    }
    private void ClearMessage()
    {
        cartMessage = string.Empty;
        StateHasChanged();
    }
}